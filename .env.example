# ── Frontend (Vite) env ──────────────────────────────────────────────────────
# These values are PUBLIC — they are bundled into the browser build. Never put a
# secret here. Copy to `.env` to use locally.

# Optional: Cloudflare Turnstile site key. When set, the access gate shows a
# Turnstile widget and the server requires a valid token. Leave blank to disable.
VITE_TURNSTILE_SITEKEY=
